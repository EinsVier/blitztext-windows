<Window x:Class="BlitzText.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="BlitzText Windows" Height="720" Width="1040" MinHeight="680" MinWidth="920"
        Background="{DynamicResource AppBackgroundBrush}">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F5F7FB" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushColor" Color="#D9DEE8" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#14171F" />
        <SolidColorBrush x:Key="BodyTextBrush" Color="#3F4654" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#5A6170" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6B7280" />
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="InputBorderBrush" Color="#AEB4BF" />
        <SolidColorBrush x:Key="NeutralButtonBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="NeutralButtonHoverBrush" Color="#D1D5DB" />
        <SolidColorBrush x:Key="NativeControlTextBrush" Color="#14171F" />
        <SolidColorBrush x:Key="StatusInfoBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="StatusSuccessBrush" Color="#16A34A" />
        <SolidColorBrush x:Key="StatusErrorBrush" Color="#DC2626" />
        <SolidColorBrush x:Key="ActiveBadgeBackgroundBrush" Color="#DCFCE7" />
        <SolidColorBrush x:Key="ActiveBadgeForegroundBrush" Color="#166534" />
        <SolidColorBrush x:Key="TooltipBackgroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="TooltipForegroundBrush" Color="#FFFFFF" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ToggleBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition />
                                                    <ColumnDefinition Width="28" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="6,0,2,0"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center"
                                                                  RecognizesAccessKey="True" />
                                                <Path Grid.Column="1"
                                                      Width="8"
                                                      Height="5"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Fill="{DynamicResource SecondaryTextBrush}"
                                                      Data="M 0 0 L 4 5 L 8 0 Z" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource BorderBrushColor}" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.58" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="8,0,32,0"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False" />
                            <TextBox x:Name="PART_EditableTextBox"
                                     Margin="8,0,32,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     Focusable="True"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"
                                     Visibility="Hidden" />
                            <Popup x:Name="Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource InputBackgroundBrush}"
                                        BorderBrush="{DynamicResource InputBorderBrush}"
                                        BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                                <Setter Property="Opacity" Value="0.62" />
                            </Trigger>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource NeutralButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource NeutralButtonBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource NeutralButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
                                <Setter Property="Panel.ZIndex" Value="1" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource NeutralButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                                <Setter TargetName="TabBorder" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource NeutralButtonHoverBrush}" />
            <Setter Property="Width" Value="16" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Background="{TemplateBinding Foreground}">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Margin="4,2"
                                                        Background="{TemplateBinding Background}" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource NeutralButtonBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1D4ED8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1E40AF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#93C5FD" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HelpTextStyle" TargetType="Label">
            <Setter Property="Content" Value="i" />
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Help" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="3" ShadowDepth="0" Opacity="0.16" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Label">
                        <Border Background="{TemplateBinding Background}"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                CornerRadius="9">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ToolTip">
            <Setter Property="MaxWidth" Value="320" />
            <Setter Property="Background" Value="{DynamicResource TooltipBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TooltipForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="12,9"
                                MaxWidth="{TemplateBinding MaxWidth}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       TextWrapping="Wrap"
                                       LineHeight="18" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActiveProviderBadgeStyle" TargetType="Label">
            <Setter Property="Content" Value="Aktiv" />
            <Setter Property="Background" Value="{DynamicResource ActiveBadgeBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource ActiveBadgeForegroundBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Margin" Value="8,2,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Label">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,20">
            <Button x:Name="RecordButton" DockPanel.Dock="Right" MinWidth="270" Height="44" Click="RecordButton_Click"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="Aufnahme starten" />
            <StackPanel>
                <TextBlock Text="BlitzText Windows" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                <TextBlock x:Name="SubtitleText" Text="Diktieren, transkribieren und direkt in die richtige App einfuegen." Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,0" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushColor}" BorderThickness="1" CornerRadius="8" Padding="18">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ControlsTitleText" Text="Bedienung" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                        <Label x:Name="ControlsHelpText" Style="{StaticResource HelpTextStyle}" />
                    </StackPanel>
                    <TextBlock x:Name="DefaultModeText" Text="Standardmodus fuer den Aufnahmebutton." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,18" />

                    <TextBlock x:Name="WorkflowLabelText" Text="Workflow" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                    <ComboBox x:Name="WorkflowCombo" Margin="0,8,0,18" Height="34" SelectionChanged="Settings_Changed" />

                    <TextBlock x:Name="TranscriptionLabelText" Text="Transkription" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                    <ComboBox x:Name="TranscriptionProviderCombo" Margin="0,8,0,18" Height="34" SelectionChanged="Settings_Changed" />

                    <TextBlock x:Name="RewriteLabelText" Text="Umschreiben" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                    <ComboBox x:Name="RewriteProviderCombo" Margin="0,8,0,18" Height="34" SelectionChanged="Settings_Changed" />

                    <TextBlock x:Name="AppLanguageLabelText" Text="App-Sprache" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                    <ComboBox x:Name="AppLanguageCombo" Margin="0,8,0,18" Height="34" SelectionChanged="Settings_Changed" />

                    <TextBlock x:Name="AppThemeLabelText" Text="Theme" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                    <ComboBox x:Name="AppThemeCombo" Margin="0,8,0,18" Height="34" SelectionChanged="Settings_Changed" />

                    <TextBlock x:Name="DictationLanguageLabelText" Text="Diktatsprache" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                    <ComboBox x:Name="DictationLanguageCombo" Margin="0,8,0,18" Height="34" SelectionChanged="Settings_Changed" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <CheckBox x:Name="AutoPasteCheckBox" Content="Nach Abschluss automatisch einfuegen" Checked="Settings_Changed" Unchecked="Settings_Changed" />
                        <Label x:Name="AutoPasteHelpText" Style="{StaticResource HelpTextStyle}" />
                    </StackPanel>
                    <CheckBox x:Name="SaveHistoryCheckBox" Content="Verlauf speichern" Margin="0,0,0,18" Checked="Settings_Changed" Unchecked="Settings_Changed" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,26">
                        <CheckBox x:Name="KeepOllamaWarmCheckBox" Content="Ollama warmhalten" Checked="Settings_Changed" Unchecked="Settings_Changed" />
                        <Label x:Name="KeepOllamaWarmHelpText" Style="{StaticResource HelpTextStyle}" />
                    </StackPanel>
                </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushColor}" BorderThickness="1" CornerRadius="8" Padding="18">
                <TabControl BorderThickness="0">
                    <TabItem x:Name="ProviderTab" Header="Provider">
                        <ScrollViewer Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="OpenAI" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <Label x:Name="OpenAiActiveBadge" Style="{StaticResource ActiveProviderBadgeStyle}" />
                                        <Label x:Name="OpenAiHelpText" Style="{StaticResource HelpTextStyle}" />
                                    </StackPanel>
                                    <TextBlock x:Name="OpenAiKeyHintText" Text="Der API-Key wird im Windows Credential Manager gespeichert." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,16" />

                                    <TextBlock Text="API Key" FontWeight="SemiBold" />
                                    <PasswordBox x:Name="OpenAiApiKeyBox" Height="32" Margin="0,8,0,14" PasswordChanged="OpenAiApiKeyBox_PasswordChanged" />

                                    <TextBlock x:Name="OpenAiTranscriptionModelLabelText" Text="Transkriptionsmodell" FontWeight="SemiBold" />
                                    <TextBox x:Name="OpenAiTranscriptionModelBox" Height="32" Margin="0,8,0,14" TextChanged="Settings_Changed" />

                                    <TextBlock x:Name="OpenAiRewriteModelLabelText" Text="Rewrite-Modell" FontWeight="SemiBold" />
                                    <TextBox x:Name="OpenAiRewriteModelBox" Height="32" Margin="0,8,0,20" TextChanged="Settings_Changed" />

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="OpenRouter" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <Label x:Name="OpenRouterActiveBadge" Style="{StaticResource ActiveProviderBadgeStyle}" />
                                        <Label x:Name="OpenRouterHelpText" Style="{StaticResource HelpTextStyle}" />
                                    </StackPanel>
                                    <TextBlock x:Name="OpenRouterHintText" Text="Optionaler Rewrite-Provider ueber OpenRouter." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,16" />

                                    <TextBlock Text="API Key" FontWeight="SemiBold" />
                                    <PasswordBox x:Name="OpenRouterApiKeyBox" Height="32" Margin="0,8,0,14" PasswordChanged="ProviderApiKeyBox_PasswordChanged" />

                                    <TextBlock x:Name="OpenRouterRewriteModelLabelText" Text="Rewrite-Modell" FontWeight="SemiBold" />
                                    <TextBox x:Name="OpenRouterRewriteModelBox" Height="32" Margin="0,8,0,20" TextChanged="Settings_Changed" />

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="LocalTranscriptionTitleText" Text="Lokale Transkription" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <Label x:Name="LocalTranscriptionHelpText" Style="{StaticResource HelpTextStyle}" />
                                    </StackPanel>
                                    <TextBlock x:Name="LocalTranscriptionHintText" Text="Optional: whisper.cpp EXE und ein lokales Whisper-Modell." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,16" />

                                    <TextBlock Text="whisper.cpp EXE" FontWeight="SemiBold" />
                                    <DockPanel LastChildFill="True" Margin="0,8,0,14">
                                        <Button x:Name="BrowseWhisperExeButton" DockPanel.Dock="Right" Content="..." Width="38" Height="32" Margin="8,0,0,0" Click="BrowseWhisperExeButton_Click" />
                                        <TextBox x:Name="LocalWhisperExecutablePathBox" Height="32" TextChanged="Settings_Changed" />
                                    </DockPanel>

                                    <TextBlock x:Name="WhisperModelLabelText" Text="Whisper-Modell" FontWeight="SemiBold" />
                                    <DockPanel LastChildFill="True" Margin="0,8,0,14">
                                        <Button x:Name="BrowseWhisperModelButton" DockPanel.Dock="Right" Content="..." Width="38" Height="32" Margin="8,0,0,0" Click="BrowseWhisperModelButton_Click" />
                                        <TextBox x:Name="LocalWhisperModelPathBox" Height="32" TextChanged="Settings_Changed" />
                                    </DockPanel>

                                    <TextBlock x:Name="WhisperModelPresetLabelText" Text="Gefundene Modelle" FontWeight="SemiBold" />
                                    <ComboBox x:Name="LocalWhisperModelCombo" Height="32" Margin="0,8,0,14" SelectionChanged="LocalWhisperModelCombo_SelectionChanged" />

                                    <TextBlock x:Name="WhisperTimeoutLabelText" Text="Timeout Sekunden" FontWeight="SemiBold" />
                                    <TextBox x:Name="LocalWhisperTimeoutBox" Height="32" Margin="0,8,0,14" TextChanged="Settings_Changed" />

                                    <Button x:Name="TestWhisperButton" Content="Whisper testen" Height="34" Margin="0,0,0,14" Click="TestWhisperButton_Click" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Ollama" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <Label x:Name="OllamaActiveBadge" Style="{StaticResource ActiveProviderBadgeStyle}" />
                                        <Label x:Name="OllamaHelpText" Style="{StaticResource HelpTextStyle}" />
                                    </StackPanel>
                                    <TextBlock x:Name="OllamaHintText" Text="Lokaler oder Netzwerk-Ollama-Server fuer Umschreiben." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,16" />

                                    <TextBlock Text="URL" FontWeight="SemiBold" />
                                    <TextBox x:Name="OllamaBaseUrlBox" Height="32" Margin="0,8,0,14" TextChanged="Settings_Changed" />

                                    <TextBlock x:Name="OllamaRewriteModelLabelText" Text="Rewrite-Modell" FontWeight="SemiBold" />
                                    <ComboBox x:Name="OllamaRewriteModelCombo" Height="32" Margin="0,8,0,18" IsEditable="True" IsTextSearchEnabled="False" SelectionChanged="OllamaRewriteModelCombo_SelectionChanged" />

                                    <Button x:Name="TestOllamaButton" Content="Ollama testen" Height="34" Margin="0,0,0,8" Click="TestOllamaButton_Click" />

                                    <StackPanel Orientation="Horizontal" Margin="0,22,0,0">
                                        <TextBlock Text="Anthropic" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <Label x:Name="AnthropicActiveBadge" Style="{StaticResource ActiveProviderBadgeStyle}" />
                                        <Label x:Name="AnthropicHelpText" Style="{StaticResource HelpTextStyle}" />
                                    </StackPanel>
                                    <TextBlock x:Name="AnthropicHintText" Text="Optionaler Rewrite-Provider fuer Claude-Modelle." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,16" />

                                    <TextBlock Text="API Key" FontWeight="SemiBold" />
                                    <PasswordBox x:Name="AnthropicApiKeyBox" Height="32" Margin="0,8,0,14" PasswordChanged="ProviderApiKeyBox_PasswordChanged" />

                                    <TextBlock x:Name="AnthropicRewriteModelLabelText" Text="Rewrite-Modell" FontWeight="SemiBold" />
                                    <TextBox x:Name="AnthropicRewriteModelBox" Height="32" Margin="0,8,0,18" TextChanged="Settings_Changed" />
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem x:Name="HotkeysTab" Header="Hotkeys">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="110" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,14" VerticalAlignment="Center">
                                <TextBlock x:Name="TranscribeHotkeyLabelText" Text="Nur transkribieren" FontWeight="SemiBold" />
                                <Label x:Name="HotkeysHelpText" Style="{StaticResource HelpTextStyle}" />
                            </StackPanel>
                            <ComboBox Grid.Row="0" Grid.Column="1" x:Name="TranscribeHotkeyCombo" Height="32" Margin="0,0,0,14" SelectionChanged="WorkflowHotkey_SelectionChanged" />
                            <Button x:Name="DetectTranscribeHotkeyButton" Grid.Row="0" Grid.Column="2" Content="Erkennen" Height="32" Margin="10,0,0,14" Click="DetectTranscribeHotkey_Click" />

                            <TextBlock x:Name="ImproveHotkeyLabelText" Grid.Row="1" Grid.Column="0" Text="Verbessern" FontWeight="SemiBold" Margin="0,0,16,14" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="ImproveHotkeyCombo" Height="32" Margin="0,0,0,14" SelectionChanged="WorkflowHotkey_SelectionChanged" />
                            <Button x:Name="DetectImproveHotkeyButton" Grid.Row="1" Grid.Column="2" Content="Erkennen" Height="32" Margin="10,0,0,14" Click="DetectImproveHotkey_Click" />

                            <TextBlock x:Name="CalmHotkeyLabelText" Grid.Row="2" Grid.Column="0" Text="Entschaerfen" FontWeight="SemiBold" Margin="0,0,16,14" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="2" Grid.Column="1" x:Name="CalmHotkeyCombo" Height="32" Margin="0,0,0,14" SelectionChanged="WorkflowHotkey_SelectionChanged" />
                            <Button x:Name="DetectCalmHotkeyButton" Grid.Row="2" Grid.Column="2" Content="Erkennen" Height="32" Margin="10,0,0,14" Click="DetectCalmHotkey_Click" />

                            <TextBlock x:Name="EmojisHotkeyLabelText" Grid.Row="3" Grid.Column="0" Text="Emojis ergaenzen" FontWeight="SemiBold" Margin="0,0,16,14" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="3" Grid.Column="1" x:Name="EmojisHotkeyCombo" Height="32" Margin="0,0,0,14" SelectionChanged="WorkflowHotkey_SelectionChanged" />
                            <Button x:Name="DetectEmojisHotkeyButton" Grid.Row="3" Grid.Column="2" Content="Erkennen" Height="32" Margin="10,0,0,14" Click="DetectEmojisHotkey_Click" />

                            <TextBlock x:Name="HotkeyStatusText" Grid.Row="4" Grid.ColumnSpan="3" Text="Workflow-Hotkeys aktiv." TextWrapping="Wrap" Foreground="{DynamicResource BodyTextBrush}" Margin="0,4,0,14" />

                            <Button x:Name="RestoreDefaultHotkeysButton" Grid.Row="5" Grid.Column="1" Content="Standard-Hotkeys wiederherstellen" Height="34" Click="RestoreDefaultHotkeysButton_Click" />
                        </Grid>
                    </TabItem>

                    <TabItem x:Name="PromptsTab" Header="Prompts">
                        <ScrollViewer Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="PromptPresetTitleText" Text="Prompt-Vorlagen (Verbessern)" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <Label x:Name="PromptPresetsHelpText" Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>
                                <TextBlock x:Name="PromptPresetHintText" Text="Diese Vorlagen setzen den Prompt fuer den Improve-Modus (Verbessern)." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,12" />
                                <DockPanel LastChildFill="True" Margin="0,0,0,18">
                                    <Button x:Name="ApplyPromptPresetButton" DockPanel.Dock="Right" Content="Anwenden" Width="96" Height="32" Margin="10,0,0,0" Click="ApplyPromptPresetButton_Click" />
                                    <ComboBox x:Name="PromptPresetCombo" Height="32" />
                                </DockPanel>
                                <Button x:Name="RestorePreviousPromptButton"
                                        Content="Vorherigen Prompt wiederherstellen"
                                        Height="32"
                                        Margin="0,-10,0,18"
                                        Visibility="Collapsed"
                                        Click="RestorePreviousPromptButton_Click" />

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="CustomNamesTitleText" Text="Eigennamen" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <Label x:Name="CustomNamesHelpText" Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>
                                <TextBlock x:Name="CustomNamesHintText" Text="Ein Name oder Begriff pro Zeile. Diese Schreibweisen werden als Kontext mitgegeben." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,12" />
                                <TextBox x:Name="CustomNamesBox" MinHeight="150" TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" TextChanged="Settings_Changed" />

                                <TextBlock x:Name="TranscriptionHintTitleText" Text="Transkriptionshinweis" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,18,0,0" />
                                <TextBlock x:Name="TranscriptionHintHelpText" Text="Optionaler Hinweis fuer Speech-to-Text, z. B. Sprache, Fachbegriffe oder Schreibweisen." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,12" />
                                <TextBox x:Name="TranscriptionPromptBox" MinHeight="92" TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" TextChanged="Settings_Changed" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="WorkflowPromptsTitleText" Text="Workflow-Prompts" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <Label x:Name="WorkflowPromptsHelpText" Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>
                                <TextBlock x:Name="WorkflowPromptsHintText" Text="Diese Zusatzanweisungen werden beim Umschreiben an OpenAI oder Ollama gesendet." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,12" />

                                <TextBlock x:Name="ImprovePromptLabelText" Text="Verbessern" FontWeight="SemiBold" />
                                <TextBox x:Name="ImprovePromptBox" MinHeight="82" Margin="0,8,0,12" TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" TextChanged="Settings_Changed" />

                                <TextBlock x:Name="CalmPromptLabelText" Text="Entschaerfen" FontWeight="SemiBold" />
                                <TextBox x:Name="CalmPromptBox" MinHeight="82" Margin="0,8,0,12" TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" TextChanged="Settings_Changed" />

                                <TextBlock x:Name="EmojisPromptLabelText" Text="Emojis ergaenzen" FontWeight="SemiBold" />
                                <TextBox x:Name="EmojisPromptBox" MinHeight="82" Margin="0,8,0,0" TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" TextChanged="Settings_Changed" />

                                <Button x:Name="ResetPromptsButton" Content="Prompts zuruecksetzen" Height="34" Margin="0,16,0,0"
                                        Click="ResetPromptsButton_Click" />
                            </StackPanel>
                        </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem x:Name="BackupTab" Header="Backup">
                        <ScrollViewer Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="AppVersionTitleText" Text="Version" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <Label x:Name="UpdatesHelpText" Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>
                                <TextBlock x:Name="AppVersionText" Text="BlitzText Windows" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,12" />
                                <TextBlock x:Name="UpdateStatusText" Text="Noch nicht nach Updates gesucht." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,12" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                                    <Button x:Name="CheckUpdatesButton" Content="Nach Updates suchen" Height="36" MinWidth="150" Click="CheckUpdatesButton_Click" />
                                    <Button x:Name="OpenUpdateButton" Content="Download oeffnen" Height="36" MinWidth="130" Margin="10,0,0,0" IsEnabled="False" Click="OpenUpdateButton_Click" />
                                </StackPanel>

                                <TextBlock x:Name="SetupCheckTitleText" Text="Konfiguration pruefen" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,0" />
                                <TextBlock x:Name="SetupCheckHintText" Text="Prueft Provider, Hotkeys, Ollama und lokale Whisper-Dateien ohne geheime Schluessel anzuzeigen." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,12" />
                                <Button x:Name="CheckSetupButton" Content="Setup pruefen" Height="36" MinWidth="130" Margin="0,0,0,12" Click="CheckSetupButton_Click" />
                                <TextBox x:Name="SetupCheckResultBox" MinHeight="120" MaxHeight="220" TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" IsReadOnly="True" Margin="0,0,0,22" />

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="ExportSettingsTitleText" Text="Einstellungen exportieren" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <Label x:Name="BackupHelpText" Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>
                                <TextBlock x:Name="ExportSettingsHintText" Text="Speichert Provider, Hotkeys, Prompts und Workflow-Auswahl als JSON-Datei. Der OpenAI-Key wird nicht exportiert." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,16" />
                                <Button x:Name="ExportSettingsButton" Content="Exportieren" Height="36" Click="ExportSettingsButton_Click" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="ImportSettingsTitleText" Text="Einstellungen importieren" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <Label x:Name="ImportSettingsHelpText" Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>
                                <TextBlock x:Name="ImportSettingsHintText" Text="Uebernimmt eine zuvor exportierte JSON-Datei. Bestehende API-Schluessel bleiben lokal erhalten." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,16" />
                                <Button x:Name="ImportSettingsButton" Content="Importieren" Height="36" Click="ImportSettingsButton_Click" />
                            </StackPanel>
                        </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem x:Name="ResultTab" Header="Ergebnis">
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Grid.ColumnSpan="3" LastChildFill="True">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button x:Name="CopyResultButton" Content="Kopieren" Width="90" Height="30" Margin="0,0,8,0" Click="CopyResultButton_Click" />
                                    <Button x:Name="DeleteHistoryEntryButton" Content="Loeschen" Width="90" Height="30" Margin="0,0,8,0" Click="DeleteHistoryEntryButton_Click" />
                                    <Button x:Name="ClearHistoryButton" Content="Verlauf leeren" Width="110" Height="30" Click="ClearHistoryButton_Click" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="ResultsTitleText" Text="Ergebnisse" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" />
                                    <Label x:Name="ResultsHelpText" Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>
                            </DockPanel>

                            <DockPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" LastChildFill="True" Margin="0,12,0,0">
                                <TextBlock x:Name="HistorySearchLabelText" DockPanel.Dock="Left" Text="Verlauf durchsuchen" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <TextBox x:Name="HistorySearchBox" Height="32" TextChanged="HistorySearchBox_TextChanged" />
                            </DockPanel>

                            <ListBox x:Name="HistoryList" Grid.Row="2" Grid.Column="0" Margin="0,12,0,0"
                                     SelectionChanged="HistoryList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="2,4">
                                            <DockPanel LastChildFill="True">
                                                <Border DockPanel.Dock="Left"
                                                        Background="{DynamicResource NeutralButtonBrush}"
                                                        Padding="6,2"
                                                        Margin="0,0,6,0">
                                                    <TextBlock Text="{Binding WorkflowLabel}" FontSize="11" FontWeight="SemiBold" />
                                                </Border>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                            </DockPanel>
                                            <TextBlock Text="{Binding Preview}" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <ScrollViewer Grid.Row="2" Grid.Column="2" Margin="0,12,0,0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <DockPanel LastChildFill="True">
                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal"
                                                    Margin="8,0,0,0">
                                            <Button x:Name="OpenSoundSettingsButton"
                                                    Width="32"
                                                    Height="32"
                                                    Padding="0"
                                                    Margin="0,0,6,0"
                                                    Click="OpenSoundSettingsButton_Click">
                                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                                           FontSize="16"
                                                           Text="&#xE713;"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Button>
                                            <Button x:Name="ResultRecordButton"
                                                    Width="32"
                                                    Height="32"
                                                    Padding="0"
                                                    BorderBrush="{DynamicResource StatusInfoBrush}"
                                                    Click="ResultRecordButton_Click">
                                                <Viewbox Width="18" Height="18">
                                                    <Path x:Name="ResultRecordIcon"
                                                          Width="20"
                                                          Height="20"
                                                          Data="M10,2 C8.35,2 7,3.35 7,5 L7,10 C7,11.65 8.35,13 10,13 C11.65,13 13,11.65 13,10 L13,5 C13,3.35 11.65,2 10,2 Z M4.5,9.5 L4.5,10 C4.5,13.04 6.96,15.5 10,15.5 C13.04,15.5 15.5,13.04 15.5,10 L15.5,9.5 M10,15.5 L10,18 M7.5,18 L12.5,18"
                                                          Fill="Transparent"
                                                          Stroke="{DynamicResource StatusInfoBrush}"
                                                          StrokeThickness="1.7"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round" />
                                                </Viewbox>
                                            </Button>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="SpokenTextTitleText"
                                                       Text="Gesprochener Text"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       VerticalAlignment="Center" />
                                            <Label x:Name="SpokenTextHelpText"
                                                   Style="{StaticResource HelpTextStyle}" />
                                        </StackPanel>
                                    </DockPanel>
                                    <TextBlock x:Name="SpokenTextHintText"
                                               Text="Die Transkription kann vor einer erneuten Verarbeitung korrigiert werden."
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Margin="0,4,0,8" />
                                    <TextBox x:Name="SourceTextBox"
                                             MinHeight="120"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             TextChanged="SourceTextBox_TextChanged" />

                                    <Grid Margin="0,12,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock x:Name="ReprocessWorkflowLabelText"
                                                       Text="Workflow fuer neue Variante"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,6" />
                                            <ComboBox x:Name="ReprocessWorkflowCombo"
                                                      Height="32"
                                                      SelectionChanged="ReprocessWorkflowCombo_SelectionChanged" />
                                        </StackPanel>
                                        <Button x:Name="ReprocessResultButton"
                                                Grid.Column="1"
                                                Content="Erneut verarbeiten"
                                                MinWidth="150"
                                                Height="32"
                                                VerticalAlignment="Bottom"
                                                Click="ReprocessResultButton_Click" />
                                    </Grid>

                                    <TextBlock x:Name="FinalTextTitleText"
                                               Text="Endgueltiger Text"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Margin="0,0,0,8" />
                                    <TextBox x:Name="ResultBox"
                                             MinHeight="150"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             IsReadOnly="True" />

                                    <Expander x:Name="PromptDetailsExpander"
                                              Foreground="{DynamicResource PrimaryTextBrush}"
                                              Margin="0,14,0,0">
                                        <Expander.Header>
                                            <TextBlock x:Name="PromptDetailsHeaderText"
                                                       Text="Prompt fuer neue Variante"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                        </Expander.Header>
                                        <StackPanel Margin="0,8,0,0">
                                            <TextBlock x:Name="PromptDetailsHintText"
                                                       Text="Zeigt den Prompt, der mit dem aktuell ausgewaehlten Workflow und Text gesendet wuerde. Dieser Text wird nicht kopiert oder eingefuegt."
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Margin="0,0,0,8" />
                                            <TextBox x:Name="PromptDetailsBox"
                                                     MinHeight="140"
                                                     MaxHeight="280"
                                                     TextWrapping="Wrap"
                                                     AcceptsReturn="True"
                                                     VerticalScrollBarVisibility="Auto"
                                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                                     IsReadOnly="True" />
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="StatusHighlightBorder"
                    Grid.Row="0"
                    BorderBrush="{DynamicResource BorderBrushColor}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusLabelText"
                               Grid.Column="0"
                               Text="Status"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />
                    <TextBlock x:Name="StatusText"
                               Grid.Column="1"
                               Text="Bereit"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource BodyTextBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="SaveStatusText"
                               Grid.Column="2"
                               Text="Aenderungen werden automatisch gespeichert."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource MutedTextBrush}"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0"
                               MaxWidth="260" />
                </Grid>
            </Border>

            <TextBlock x:Name="FooterText"
                       Grid.Row="1"
                       Margin="0,8,0,0"
                       Foreground="{DynamicResource MutedTextBrush}"
                       Text="Hotkey druecken, sprechen, Hotkey erneut druecken. Das Ergebnis landet in der Zwischenablage oder direkt im Ziel-Fenster." />
        </Grid>
    </Grid>
</Window>
