<Window x:Class="BlitzText.Windows.HotkeyCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Taste erkennen"
        Height="220"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FB"
        KeyDown="Window_KeyDown">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Taste erkennen" FontSize="22" FontWeight="SemiBold" Foreground="#14171F" />
            <TextBlock Text="Druecke jetzt die gewuenschte Taste oder Tastenkombination." TextWrapping="Wrap" Foreground="#5A6170" Margin="0,8,0,0" />
        </StackPanel>

        <Border Grid.Row="1" Background="White" BorderBrush="#D9DEE8" BorderThickness="1" Margin="0,18,0,18" Padding="16">
            <TextBlock x:Name="DetectedText" Text="Warte auf Tastendruck..." FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" />
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Abbrechen" Width="100" Height="32" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
